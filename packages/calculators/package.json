{
  "name": "@estimatorsuite/calculators",
  "version": "0.1.0",
  "description": "42 React construction calculators and pure calculation functions — concrete, roofing, flooring, HVAC, plumbing, markup, and more. Built for estimating contractors.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./src/styles/theme.css",
    "./data": {
      "import": {
        "types": "./dist/data/index.d.ts",
        "default": "./dist/data/index.js"
      },
      "require": {
        "types": "./dist/data/index.d.cts",
        "default": "./dist/data/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src/styles",
    "src/components/*/index.ts",
    "src/components/*.tsx",
    "src/shared/*.tsx",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "construction",
    "calculator",
    "concrete",
    "roofing",
    "estimating",
    "contractor",
    "react",
    "react-components",
    "typescript",
    "material-calculator",
    "cost-estimator",
    "hvac",
    "plumbing"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/estimatorsuite/construction-calculators"
  },
  "homepage": "https://estimatorsuite.github.io/construction-calculators/",
  "author": "EstimatorSuite",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "@types/react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "lucide-react": "^1.11.0",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
